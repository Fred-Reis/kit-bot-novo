generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Owner {
  id         String     @id @default(uuid())
  name       String
  phone      String     @unique
  email      String?    @unique
  properties Property[]
  createdAt  DateTime   @default(now())
}

model Property {
  id                     String          @id @default(uuid())
  externalId             String          @unique
  ownerId                String
  owner                  Owner           @relation(fields: [ownerId], references: [id])
  name                   String
  title                  String?
  address                String
  complement             String?
  neighborhood           String
  category               String?
  type                   String?
  purpose                String?
  status                 String          @default("available")
  description            String?
  rent                   Decimal
  deposit                Decimal
  depositInstallmentsMax Int
  contractMonths         Int?
  rooms                  Int
  bathrooms              Int
  area                   Float?
  parkingSpots           Int?
  amenities              String[]        @default([])
  includesWater          Boolean         @default(false)
  includesIptu           Boolean         @default(false)
  individualElectricity  Boolean         @default(true)
  firstRental            Boolean         @default(false)
  independentEntrance    Boolean         @default(true)
  acceptsPets            Boolean         @default(false)
  maxAdults              Int             @default(2)
  acceptsChildren        Boolean         @default(true)
  visitSchedule          String?
  listingUrl             String?
  rulesText              String?
  active                 Boolean         @default(true)
  media                  PropertyMedia[]
  leads                  Lead[]
  tenants                Tenant[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
}

model PropertyMedia {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  type       String   // "photo" | "video" | "listing"
  url        String
  label      String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model Lead {
  id               String         @id @default(uuid())
  phone            String         @unique
  name             String?
  source           String?
  propertyId       String?
  property         Property?      @relation(fields: [propertyId], references: [id])
  stage            String         @default("interest")
  contractUrl      String?
  autentiqueDocId  String?
  visitedAt        DateTime?
  docsSentAt       DateTime?
  contractSignedAt DateTime?
  documents        LeadDocument[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model LeadDocument {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  type      String   // "cnh" | "rg_cpf" | "cpf" | "image"
  url       String
  ocrText   String?
  createdAt DateTime @default(now())
}

model Tenant {
  id            String    @id @default(uuid())
  externalId    String?   @unique
  phone         String    @unique
  propertyId    String
  property      Property  @relation(fields: [propertyId], references: [id])
  name          String?
  cpf           String?
  email         String?
  score         Int?
  dueDay        Int?
  onTimeRate    Float?
  contractStart DateTime
  contractEnd   DateTime?
  payments      Payment[]
  createdAt     DateTime  @default(now())
}

model Payment {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  month     String
  amount    Decimal
  status    String
  paidAt    DateTime?
  createdAt DateTime  @default(now())
}

model Event {
  id        String   @id @default(uuid())
  chatId    String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  @@index([chatId])
}

model Conversation {
  chatId    String   @id
  data      Json
  updatedAt DateTime @updatedAt
}
