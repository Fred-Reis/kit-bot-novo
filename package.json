{
  "name": "kit-manager",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:bot": "bun run dev --cwd apps/bot",
    "dev:web": "bun run dev --cwd apps/web",
    "typecheck": "bun run typecheck --cwd apps/bot && bun run typecheck --cwd apps/web && bun run typecheck --cwd packages/types",
    "lint": "oxlint --config .oxlintrc.json apps/bot/src apps/web/src packages",
    "lint:bot": "oxlint --config .oxlintrc.json apps/bot/src",
    "lint:web": "oxlint --config .oxlintrc.json apps/web/src packages",
    "format": "biome format --write apps/bot/src apps/web/src packages",
    "format:check": "biome format apps/bot/src apps/web/src packages"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "oxlint": "^0.16.0"
  },
  "msw": {
    "workerDirectory": [
      "apps/web/public"
    ]
  }
}